<%- include('../layouts/header') %>

  <div class="container">
    <h2 class="mb-30"><%= isEdit ? 'Edit Movie' : 'Create Movie' %></h2>

    <div class="movie-detail-container">
      <form id="movieForm" action="<%= isEdit ? '/movies/edit/' + movie._id : '/movies/create' %>" method="POST"
        enctype="multipart/form-data" style="display: contents;">
        <input type="hidden" name="returnTo" value="<%= returnTo || '/movies' %>">

        <!-- Left Side: Movie Poster Upload -->
        <div class="movie-detail-poster">
          <label for="picture" style="cursor: pointer; display: block;">
            <img id="placeholderImg"
              src="<%= isEdit && movie.pictureUrl ? movie.pictureUrl : '/images/cameraplaceholder.jpg' %>"
              alt="Upload movie image"
              style="width: 100%; border-radius: 8px; border: 2px dashed #94a3b8; object-fit: cover; min-height: 400px;">
          </label>
          <input type="file" id="picture" name="picture" accept="image/*" style="display: none;">
          <input type="hidden" id="pictureUrl" name="pictureUrl" value="<%= movie && movie.pictureUrl ? movie.pictureUrl : '' %>">
          <input type="hidden" id="imdbId" name="imdbId" value="<%= movie && movie.imdbId ? movie.imdbId : '' %>">
          <p class="form-help-text">Click to upload poster</p>
        </div>

        <!-- Right Side: Form Fields -->
        <div class="movie-detail-info">

          <!-- Movie Name -->
          <div class="form-group">
            <div class="label-row">
              <label for="name" class="form-label">Movie Name * <span style="font-size: 10px; font-weight: 400;">(max 50 characters)</span></label>
              <% if (typeof error !== 'undefined' && error) { %>
                <span class="error-inline">
                  <i class="bi bi-exclamation-triangle" style="font-size: 13px;"></i> <%= error %>
                </span>
              <% } %>
            </div>
            <input type="text" id="name" name="name" class="form-control" value="<%= movie ? movie.name : '' %>" required maxlength="50">
          </div>

          <div class="form-group" style="margin-top: -6px;">
            <button type="button" id="omdbSearchBtn" class="btn btn-secondary">
              <i class="bi bi-cloud-arrow-down"></i> Search IMDb Cloud
            </button>
            <div id="omdbSearchStatus" class="form-help-text" style="margin-top: 8px;"></div>
            <div id="omdbPicker" class="card" style="display: none; margin-top: 10px; max-height: 320px; overflow-y: auto;"></div>
          </div>

          <!-- Row 1: Duration, Rating, Age Restriction -->
          <div class="form-row">
            <div class="form-group">
              <label for="duration" class="form-label">Duration (mins)</label>
              <input type="number" id="duration" name="duration" class="form-control" value="<%= movie ? movie.duration : '' %>" min="1" step="1" required>
            </div>

            <div class="form-group">
              <label for="rating" class="form-label">Rating</label>
              <input type="number" id="rating" name="rating" class="form-control" value="<%= movie ? movie.rating : '' %>" min="0" max="5" step="0.1">
            </div>

            <div class="form-group">
              <label for="ageRestriction" class="form-label">Age Restriction</label>
              <select id="ageRestriction" name="ageRestriction" class="form-control">
                <option value="">Select</option>
                <option value="G" <%=movie && movie.ageRestriction==='G' ? 'selected' : '' %>>G</option>
                <option value="PG" <%=movie && movie.ageRestriction==='PG' ? 'selected' : '' %>>PG</option>
                <option value="PG13" <%=movie && movie.ageRestriction==='PG13' ? 'selected' : '' %>>PG13</option>
                <option value="NC16" <%=movie && movie.ageRestriction==='NC16' ? 'selected' : '' %>>NC16</option>
                <option value="M18" <%=movie && movie.ageRestriction==='M18' ? 'selected' : '' %>>M18</option>
                <option value="R21" <%=movie && movie.ageRestriction==='R21' ? 'selected' : '' %>>R21</option>
              </select>
            </div>
          </div>

          <!-- Row 2: Producer and Genre -->
          <div class="form-row">
            <div class="form-group">
              <label for="producer" class="form-label">Director</label>
              <input type="text" id="producer" name="producer" class="form-control" value="<%= movie ? movie.producer : '' %>">
            </div>

            <div class="form-group">
              <label for="genre" class="form-label">Genre</label>
              <input type="text" id="genre" name="genre" class="form-control"
                value="<%= movie && Array.isArray(movie.genre) ? movie.genre.join(', ') : (movie ? movie.genre : '') %>"
                placeholder="e.g. Action, Thriller">
            </div>
          </div>

          <!-- Row 3: Language and Subtitle -->
          <div class="form-row">
            <div class="form-group">
              <label for="language" class="form-label">Language</label>
              <select id="language" name="language" class="form-control" required>
                <option value="">Select</option>
                <option value="English" <%=movie && movie.language==='English' ? 'selected' : '' %>>English</option>
                <option value="Mandarin" <%=movie && movie.language==='Mandarin' ? 'selected' : '' %>>Mandarin</option>
                <option value="Malay" <%=movie && movie.language==='Malay' ? 'selected' : '' %>>Malay</option>
                <option value="Tamil" <%=movie && movie.language==='Tamil' ? 'selected' : '' %>>Tamil</option>
                <option value="Hindi" <%=movie && movie.language==='Hindi' ? 'selected' : '' %>>Hindi</option>
              </select>
            </div>

            <div class="form-group">
              <label for="subtitle" class="form-label">Subtitle</label>
              <select id="subtitle" name="subtitle" class="form-control">
                <option value="">Select</option>
                <option value="English" <%=movie && movie.subtitle==='English' ? 'selected' : '' %>>English</option>
                <option value="Mandarin" <%=movie && movie.subtitle==='Mandarin' ? 'selected' : '' %>>Mandarin</option>
                <option value="Malay" <%=movie && movie.subtitle==='Malay' ? 'selected' : '' %>>Malay</option>
                <option value="Tamil" <%=movie && movie.subtitle==='Tamil' ? 'selected' : '' %>>Tamil</option>
                <option value="Hindi" <%=movie && movie.subtitle==='Hindi' ? 'selected' : '' %>>Hindi</option>
              </select>
            </div>
          </div>

          <!-- Row 4: Release Date and Status -->
          <div class="form-row">
            <div class="form-group">
              <label for="releaseDate" class="form-label">Release Date</label>
              <input type="date" id="releaseDate" name="releaseDate" class="form-control"
                value="<%= movie && movie.releaseDate ? new Date(movie.releaseDate).toISOString().split('T')[0] : '' %>">
            </div>

            <div class="form-group">
              <label for="status" class="form-label">Status</label>
              <select id="status" name="status" class="form-control">
                <option value="">Select</option>
                <option value="Now Showing" <%=movie && movie.status==='Now Showing' ? 'selected' : '' %>>Now Showing</option>
                <option value="Advance Sales" <%=movie && movie.status==='Advance Sales' ? 'selected' : '' %>>Advance Sales</option>
                <option value="Coming Soon" <%=movie && movie.status==='Coming Soon' ? 'selected' : '' %>>Coming Soon</option>
                <option value="Discontinued" <%=movie && movie.status==='Discontinued' ? 'selected' : '' %>>Discontinued</option>
              </select>
            </div>
          </div>

          <!-- Cast (Full Width) -->
          <div class="form-group">
            <label for="cast" class="form-label">Main Cast</label>
            <input type="text" id="cast" name="cast" class="form-control"
              value="<%= movie && Array.isArray(movie.cast) ? movie.cast.join(', ') : (movie ? movie.cast : '') %>"
              placeholder="e.g. Tom Cruise, Zendaya">
          </div>

          <!-- Description (Full Width) -->
          <div class="form-group">
            <label for="description" class="form-label">Synopsis <span style="font-size: 10px; font-weight: 400;">(max 150 words)</span></label>
            <textarea id="description" name="description" rows="5"
              class="form-control" style="resize: vertical;"><%= movie ? movie.description : '' %></textarea>
            <p id="descriptionWordCount" class="form-help-text" style="margin-top: 6px;">0/150 words</p>
          </div>

          <!-- Action Buttons -->
          <div class="movie-detail-actions">
            <a href="<%= returnTo || '/movies' %>" class="btn btn-secondary">
              ← Back to Movies
            </a>
            <button type="submit" class="btn btn-primary">
              <%= isEdit ? 'Update Movie' : 'Create Movie' %>
            </button>
          </div>

        </div>

      </form>
    </div>
  </div>

  <script>
    const pictureInput = document.getElementById('picture');
    const pictureUrlInput = document.getElementById('pictureUrl');
    const imdbIdInput = document.getElementById('imdbId');
    const placeholderImg = document.getElementById('placeholderImg');
    const movieForm = document.getElementById('movieForm');
    const nameInput = document.getElementById('name');
    const durationInput = document.getElementById('duration');
    const ratingInput = document.getElementById('rating');
    const ageRestrictionInput = document.getElementById('ageRestriction');
    const languageInput = document.getElementById('language');
    const subtitleInput = document.getElementById('subtitle');
    const releaseDateInput = document.getElementById('releaseDate');
    const statusInput = document.getElementById('status');
    const descriptionInput = document.getElementById('description');
    const descriptionWordCount = document.getElementById('descriptionWordCount');
    const omdbSearchBtn = document.getElementById('omdbSearchBtn');
    const omdbSearchStatus = document.getElementById('omdbSearchStatus');
    const omdbPicker = document.getElementById('omdbPicker');
    const fallbackPoster = '/images/cameraplaceholder.jpg';
    const synopsisMaxWords = 150;
    const allowedAgeRestrictions = new Set(['', 'G', 'PG', 'PG13', 'NC16', 'M18', 'R21']);
    const allowedLanguages = new Set(['English', 'Mandarin', 'Malay', 'Tamil', 'Hindi']);
    const allowedSubtitles = new Set(['', 'English', 'Mandarin', 'Malay', 'Tamil', 'Hindi']);
    const allowedStatuses = new Set(['', 'Now Showing', 'Advance Sales', 'Coming Soon', 'Discontinued']);
    const isoDatePattern = /^\d{4}-\d{2}-\d{2}$/;
    const uploadPathPattern = /^\/uploads\/[A-Za-z0-9._-]+$/;

    function getWordCount(value) {
      const text = (value || '').trim();
      if (!text) return 0;
      return text.split(/\s+/).length;
    }

    function validateSynopsisLimit() {
      if (!descriptionInput) return true;
      const words = getWordCount(descriptionInput.value);
      const isValid = words <= synopsisMaxWords;
      descriptionInput.setCustomValidity(
        isValid ? '' : `Synopsis cannot exceed ${synopsisMaxWords} words.`
      );
      return isValid;
    }

    function updateSynopsisWordCount() {
      if (!descriptionInput || !descriptionWordCount) return;
      const words = getWordCount(descriptionInput.value);
      descriptionWordCount.textContent = `${words}/${synopsisMaxWords} words`;
      descriptionWordCount.style.color = words > synopsisMaxWords ? '#dc3545' : '#6b7280';
      validateSynopsisLimit();
    }

    function isValidIsoDate(value) {
      if (!value) return true;
      if (!isoDatePattern.test(value)) return false;
      const date = new Date(`${value}T00:00:00.000Z`);
      return !Number.isNaN(date.getTime()) && date.toISOString().slice(0, 10) === value;
    }

    function isValidPictureUrl(value) {
      if (!value) return true;
      if (uploadPathPattern.test(value)) return true;
      try {
        const url = new URL(value);
        return url.protocol === 'http:' || url.protocol === 'https:';
      } catch (_error) {
        return false;
      }
    }

    function validateSelectValue(field, allowedValues, requiredMessage, invalidMessage) {
      if (!field) return true;
      const value = (field.value || '').trim();

      if (requiredMessage && !value) {
        field.setCustomValidity(requiredMessage);
        return false;
      }

      if (!allowedValues.has(value)) {
        field.setCustomValidity(invalidMessage);
        return false;
      }

      field.setCustomValidity('');
      return true;
    }

    function validateFormFields() {
      let firstInvalidField = null;

      if (nameInput) {
        const trimmedName = (nameInput.value || '').trim();
        nameInput.value = trimmedName;
        if (!trimmedName) {
          nameInput.setCustomValidity('Movie name is required.');
          firstInvalidField = firstInvalidField || nameInput;
        } else if (trimmedName.length > 50) {
          nameInput.setCustomValidity('Movie name cannot exceed 50 characters.');
          firstInvalidField = firstInvalidField || nameInput;
        } else {
          nameInput.setCustomValidity('');
        }
      }

      if (durationInput) {
        const rawDuration = (durationInput.value || '').trim();
        durationInput.value = rawDuration;
        if (!rawDuration || !/^\d+$/.test(rawDuration) || Number.parseInt(rawDuration, 10) <= 0) {
          durationInput.setCustomValidity('Duration must be a whole number greater than 0.');
          firstInvalidField = firstInvalidField || durationInput;
        } else {
          durationInput.setCustomValidity('');
        }
      }

      if (ratingInput) {
        const rawRating = (ratingInput.value || '').trim();
        ratingInput.value = rawRating;
        if (rawRating) {
          const parsedRating = Number(rawRating);
          if (!Number.isFinite(parsedRating) || parsedRating < 0 || parsedRating > 5) {
            ratingInput.setCustomValidity('Rating must be a number between 0 and 5.');
            firstInvalidField = firstInvalidField || ratingInput;
          } else {
            ratingInput.setCustomValidity('');
          }
        } else {
          ratingInput.setCustomValidity('');
        }
      }

      if (!validateSelectValue(ageRestrictionInput, allowedAgeRestrictions, '', 'Invalid age restriction selected.')) {
        firstInvalidField = firstInvalidField || ageRestrictionInput;
      }

      if (!validateSelectValue(languageInput, allowedLanguages, 'Please select a valid language.', 'Please select a valid language.')) {
        firstInvalidField = firstInvalidField || languageInput;
      }

      if (!validateSelectValue(subtitleInput, allowedSubtitles, '', 'Invalid subtitle selected.')) {
        firstInvalidField = firstInvalidField || subtitleInput;
      }

      if (!validateSelectValue(statusInput, allowedStatuses, '', 'Invalid status selected.')) {
        firstInvalidField = firstInvalidField || statusInput;
      }

      if (releaseDateInput) {
        const dateValue = (releaseDateInput.value || '').trim();
        releaseDateInput.value = dateValue;
        if (!isValidIsoDate(dateValue)) {
          releaseDateInput.setCustomValidity('Invalid release date.');
          firstInvalidField = firstInvalidField || releaseDateInput;
        } else {
          releaseDateInput.setCustomValidity('');
        }
      }

      if (pictureUrlInput) {
        const urlValue = (pictureUrlInput.value || '').trim();
        pictureUrlInput.value = urlValue;
        if (!isValidPictureUrl(urlValue)) {
          pictureUrlInput.setCustomValidity('Poster URL must be a valid URL or uploaded file path.');
          firstInvalidField = firstInvalidField || pictureUrlInput;
        } else {
          pictureUrlInput.setCustomValidity('');
        }
      }

      if (imdbIdInput) {
        imdbIdInput.value = (imdbIdInput.value || '').trim();
      }

      if (descriptionInput) {
        descriptionInput.value = (descriptionInput.value || '').trim();
      }

      if (!validateSynopsisLimit()) {
        firstInvalidField = firstInvalidField || descriptionInput;
      }

      return firstInvalidField;
    }

    function setPosterPreview(src) {
      if (!placeholderImg) return;
      placeholderImg.src = src || fallbackPoster;
    }

    function setSearchStatus(message, isError) {
      if (!omdbSearchStatus) return;
      omdbSearchStatus.textContent = message || '';
      omdbSearchStatus.style.color = isError ? '#dc3545' : '#6b7280';
    }

    function setFieldValue(fieldId, value) {
      const field = document.getElementById(fieldId);
      if (!field) return;
      field.value = value == null ? '' : value;
    }

    function clearPicker() {
      if (!omdbPicker) return;
      omdbPicker.innerHTML = '';
      omdbPicker.style.display = 'none';
    }

    function populateMovieForm(movieData) {
      if (!movieData) return;

      setFieldValue('name', movieData.name || '');
      setFieldValue('duration', movieData.duration || '');
      setFieldValue('rating', movieData.rating || '');
      setFieldValue('ageRestriction', movieData.ageRestriction || '');
      setFieldValue('producer', movieData.producer || '');
      setFieldValue('genre', movieData.genre || '');
      setFieldValue('language', movieData.language || '');
      setFieldValue('subtitle', movieData.subtitle || '');
      setFieldValue('releaseDate', movieData.releaseDate || '');
      setFieldValue('status', movieData.status || '');
      setFieldValue('cast', movieData.cast || '');
      setFieldValue('description', movieData.description || '');
      setFieldValue('imdbId', movieData.imdbId || '');
      updateSynopsisWordCount();

      if (pictureInput) {
        pictureInput.value = '';
      }

      if (pictureUrlInput) {
        pictureUrlInput.value = movieData.pictureUrl || '';
      }

      setPosterPreview(movieData.pictureUrl || fallbackPoster);
    }

    function buildPickerItem(result) {
      const itemBtn = document.createElement('button');
      itemBtn.type = 'button';
      itemBtn.className = 'btn btn-secondary';
      itemBtn.style.width = '100%';
      itemBtn.style.display = 'flex';
      itemBtn.style.alignItems = 'center';
      itemBtn.style.gap = '10px';
      itemBtn.style.marginBottom = '8px';
      itemBtn.style.textAlign = 'left';

      const thumb = document.createElement('img');
      thumb.src = result.posterUrl || fallbackPoster;
      thumb.alt = result.title || 'Movie poster';
      thumb.style.width = '40px';
      thumb.style.height = '60px';
      thumb.style.objectFit = 'cover';
      thumb.style.borderRadius = '4px';

      const textWrap = document.createElement('div');
      const titleLine = document.createElement('div');
      titleLine.textContent = result.title || 'Untitled';
      titleLine.style.fontWeight = '600';

      const subLine = document.createElement('div');
      subLine.textContent = `${result.year || ''}`.trim();
      subLine.style.fontSize = '12px';
      subLine.style.opacity = '0.8';

      textWrap.appendChild(titleLine);
      textWrap.appendChild(subLine);

      itemBtn.appendChild(thumb);
      itemBtn.appendChild(textWrap);

      itemBtn.addEventListener('click', async () => {
        try {
          setSearchStatus('Fetching movie details...', false);
          omdbSearchBtn.disabled = true;

          const response = await fetch(`/movies/omdb/details?imdbId=${encodeURIComponent(result.imdbId)}`);
          const data = await response.json();
          if (!response.ok) {
            throw new Error(data.error || 'Unable to fetch OMDB details');
          }

          populateMovieForm(data.movie);
          clearPicker();
          setSearchStatus('Form populated from OMDB. You can still edit any field or upload your own poster.', false);
        } catch (error) {
          setSearchStatus(error.message || 'Failed to fetch OMDB details', true);
        } finally {
          omdbSearchBtn.disabled = false;
        }
      });

      return itemBtn;
    }

    async function searchOmdbByTitle() {
      const title = (nameInput && nameInput.value ? nameInput.value : '').trim();
      if (!title) {
        setSearchStatus('Enter a movie name first.', true);
        clearPicker();
        return;
      }

      try {
        setSearchStatus('Searching OMDB...', false);
        clearPicker();
        omdbSearchBtn.disabled = true;

        const response = await fetch(`/movies/omdb/search?title=${encodeURIComponent(title)}`);
        const data = await response.json();
        if (!response.ok) {
          throw new Error(data.error || 'Unable to search OMDB');
        }

        const results = Array.isArray(data.results) ? data.results : [];
        if (!results.length) {
          setSearchStatus(data.error || 'No matches found.', true);
          clearPicker();
          return;
        }

        omdbPicker.style.display = 'block';
        results.forEach((result) => {
          omdbPicker.appendChild(buildPickerItem(result));
        });

        setSearchStatus(`Found ${results.length} result(s). Select one to populate the form.`, false);
      } catch (error) {
        setSearchStatus(error.message || 'Failed to search OMDB', true);
        clearPicker();
      } finally {
        omdbSearchBtn.disabled = false;
      }
    }

    if (pictureInput) {
      pictureInput.addEventListener('change', () => {
        const file = pictureInput.files[0];
        if (file) {
          setPosterPreview(URL.createObjectURL(file));
          if (pictureUrlInput) pictureUrlInput.value = '';
        }
      });
    }

    if (omdbSearchBtn) {
      omdbSearchBtn.addEventListener('click', searchOmdbByTitle);
    }

    if (descriptionInput) {
      descriptionInput.addEventListener('input', updateSynopsisWordCount);
      updateSynopsisWordCount();
    }

    if (movieForm) {
      movieForm.addEventListener('submit', (event) => {
        const firstInvalidField = validateFormFields();
        if (firstInvalidField) {
          event.preventDefault();
          firstInvalidField.reportValidity();
        }
      });
    }
  </script>

  <%- include('../layouts/footer') %>
