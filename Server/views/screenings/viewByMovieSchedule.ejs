<%- include('../layouts/header') %>

<div class="container">
    <h2 class="mb-30"><%= movie.name %> - Screenings</h2>

    <div class="movie-detail-container">
        <!-- Left Side: Movie Poster -->
        <div class="movie-detail-poster">
            <img src="<%= movie.pictureUrl || '/images/placeholder.jpg' %>"
                alt="<%= movie.name %>"
                class="detail-cover-img">
            <div class="detail-meta-block detail-meta-block-left">
                <h4 class="detail-meta-title"><%= movie.name %></h4>
                <p class="detail-meta-subtitle"><%= movie.duration %> mins</p>
                <% if (movie.genre) { %>
                    <div class="genre-tags genre-tags-left mt-15">
                        <% if (Array.isArray(movie.genre)) { %>
                            <% movie.genre.forEach(g => { %>
                                <span class="genre-tag"><%= g %></span>
                            <% }); %>
                        <% } else { %>
                            <span class="genre-tag"><%= movie.genre %></span>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Right Side: Screenings by Date -->
        <div class="movie-detail-info schedule-info-fixed">
            
            <label class="form-label schedule-section-label">AVAILABLE SCREENINGS</label>
            
            <% if (Object.keys(screeningsByDate).length === 0) { %>
                <div class="schedule-panel schedule-empty-state">
                    <i class="bi bi-calendar-x schedule-empty-icon"></i>
                    <p class="schedule-empty-text">No screenings scheduled for this movie</p>
                </div>
            <% } else { %>
                <div id="movieScheduleDatesContainer" class="schedule-date-list">
                    <% Object.keys(screeningsByDate).forEach(date => { %>
                        <div class="movie-schedule-date-card schedule-date-card">
                            <!-- Date Header -->
                            <div class="schedule-card-header">
                                <i class="bi bi-calendar3 schedule-card-icon"></i>
                                <h4 class="schedule-card-title"><%= date %></h4>
                            </div>
                            
                            <!-- Timings Grid -->
                            <div class="schedule-time-grid">
                                <% screeningsByDate[date].forEach(screening => { %>
                                    <a href="/screenings/view/<%= screening.screeningId %>?returnTo=<%= encodeURIComponent('/screenings/movie/' + movie._id) %>"
                                       class="schedule-time-chip <%= screening.status === 'paused' ? 'schedule-time-chip-paused' : '' %>"
                                       title="View screening in <%= screening.hallName %>">
                                        <div class="schedule-time-value">
                                            <%= screening.time %>
                                        </div>
                                        <div class="schedule-time-subtext">
                                            <%= screening.hallName %>
                                        </div>
                                        <% if (screening.status === 'paused') { %>
                                          <div class="schedule-time-alert" aria-label="Paused due to maintenance">
                                            <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                                            <span>Paused</span>
                                          </div>
                                        <% } %>
                                    </a>
                                <% }); %>
                            </div>
                        </div>
                    <% }); %>
                </div>

                <div id="movieSchedulePagination" class="pagination-container schedule-pagination">
                    <button id="movieSchedulePrevPage" class="pagination-btn" disabled>
                        <i class="bi bi-chevron-left"></i> Previous
                    </button>
                    <div id="movieSchedulePageNumbers" class="page-numbers"></div>
                    <button id="movieScheduleNextPage" class="pagination-btn">
                        Next <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            <% } %>

            <!-- Back Button -->
            <div class="movie-detail-actions schedule-actions-margin">
                <a href="/screenings?view=movie" class="btn btn-secondary">
                    ← Back to Movie List
                </a>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const dateCards = Array.from(document.querySelectorAll('#movieScheduleDatesContainer .movie-schedule-date-card'));
        const prevPageBtn = document.getElementById('movieSchedulePrevPage');
        const nextPageBtn = document.getElementById('movieScheduleNextPage');
        const pageNumbersDiv = document.getElementById('movieSchedulePageNumbers');
        const paginationContainer = document.getElementById('movieSchedulePagination');

        if (!dateCards.length || !prevPageBtn || !nextPageBtn || !pageNumbersDiv || !paginationContainer) {
            return;
        }

        let currentPage = 1;
        const itemsPerPage = 3;

        function renderPage() {
            const totalPages = Math.ceil(dateCards.length / itemsPerPage);
            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;

            dateCards.forEach((card, index) => {
                card.style.display = (index >= startIndex && index < endIndex) ? 'block' : 'none';
            });

            prevPageBtn.disabled = currentPage === 1;
            nextPageBtn.disabled = currentPage === totalPages || totalPages === 0;
            pageNumbersDiv.innerHTML = '';
            if (totalPages > 0) {
                const pageInfo = document.createElement('span');
                pageInfo.className = 'page-number active';
                pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
                pageNumbersDiv.appendChild(pageInfo);
            }
        }

        prevPageBtn.addEventListener('click', function() {
            if (currentPage > 1) {
                currentPage--;
                renderPage();
            }
        });

        nextPageBtn.addEventListener('click', function() {
            const totalPages = Math.ceil(dateCards.length / itemsPerPage);
            if (currentPage < totalPages) {
                currentPage++;
                renderPage();
            }
        });

        renderPage();
    });
</script>

<%- include('../layouts/footer') %>
