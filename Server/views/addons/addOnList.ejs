<%- include('../layouts/header') %>

<div class="container">
  <h2 class="page-title">Add-Ons</h2>

  <div class="movie-filters">
    <button class="filter-btn active" data-filter="all">
      <i class="bi bi-grid-3x3-gap"></i> All
    </button>
  </div>

  <div class="search-filter-bar">
    <div class="search-controls">
      <div class="search-box">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
          <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
        </svg>
        <input type="text" id="addOnSearch" class="search-input" placeholder="Search add-ons...">
      </div>

      <div class="filter-dropdown">
        <select id="addOnSort" class="filter-select">
          <option value="newest">Newest First</option>
          <option value="oldest">Oldest First</option>
          <option value="nameAZ">Name (A-Z)</option>
          <option value="nameZA">Name (Z-A)</option>
          <option value="priceHigh">Price (High-Low)</option>
          <option value="priceLow">Price (Low-High)</option>
        </select>
      </div>
    </div>

    <div class="create-button-wrapper">
      <% if (currentRole !== 'Staff') { %>
        <a href="/addons/create" class="btn btn-primary">
          <i class="bi bi-plus-square"></i> Create New Add-On
        </a>
      <% } %>
    </div>
  </div>

  <div class="movies-grid">
    <% addOns.forEach((addOn) => { %>
      <a
        href="/addons/<%= addOn._id %>?returnTo=<%= encodeURIComponent('/addons') %>"
        class="movie-card-link"
        data-name="<%= (addOn.name || '').toLowerCase() %>"
        data-price="<%= Number(addOn.price || 0) %>"
        data-created="<%= addOn.created ? new Date(addOn.created).toISOString() : '' %>"
      >
        <div class="movie-card card">
          <div class="movie-card-img-wrapper">
            <img
              src="<%= addOn.pictureUrl || '/images/placeholder.jpg' %>"
              alt="<%= addOn.name || 'Add-On' %>"
              class="movie-card-img"
            >
          </div>
          <div class="movie-card-content">
            <div class="movie-name"><%= addOn.name || 'Untitled Add-On' %></div>
            <div class="movie-duration">
              <i class="bi bi-currency-dollar" style="margin-right: 4px;"></i>
              <%= Number(addOn.price || 0).toLocaleString('en-SG', { style: 'currency', currency: 'SGD' }) %>
            </div>
            <div class="movie-duration">
              <%= addOn.description || 'No description' %>
            </div>
          </div>
        </div>
      </a>
    <% }); %>
  </div>

  <div class="pagination-container">
    <button id="prevPage" class="pagination-btn" disabled>
      <i class="bi bi-chevron-left"></i> Previous
    </button>
    <div id="pageNumbers" class="page-numbers"></div>
    <button id="nextPage" class="pagination-btn">
      Next <i class="bi bi-chevron-right"></i>
    </button>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const cards = Array.from(document.querySelectorAll(".movie-card-link"));
    const searchInput = document.getElementById("addOnSearch");
    const sortFilter = document.getElementById("addOnSort");
    const prevPageBtn = document.getElementById("prevPage");
    const nextPageBtn = document.getElementById("nextPage");
    const pageNumbersDiv = document.getElementById("pageNumbers");
    const grid = document.querySelector(".movies-grid");

    let currentPage = 1;
    const itemsPerPage = 20;

    function getFiltered() {
      const term = (searchInput.value || "").trim().toLowerCase();
      return cards.filter((card) => {
        const name = card.dataset.name || "";
        return !term || name.includes(term);
      });
    }

    function sortCards(items) {
      const sortValue = sortFilter.value;
      const sorted = [...items];

      if (sortValue === "nameAZ") {
        sorted.sort((a, b) => (a.dataset.name || "").localeCompare(b.dataset.name || ""));
      } else if (sortValue === "nameZA") {
        sorted.sort((a, b) => (b.dataset.name || "").localeCompare(a.dataset.name || ""));
      } else if (sortValue === "priceHigh") {
        sorted.sort((a, b) => Number(b.dataset.price || 0) - Number(a.dataset.price || 0));
      } else if (sortValue === "priceLow") {
        sorted.sort((a, b) => Number(a.dataset.price || 0) - Number(b.dataset.price || 0));
      } else if (sortValue === "oldest") {
        sorted.sort((a, b) => new Date(a.dataset.created || 0) - new Date(b.dataset.created || 0));
      } else {
        sorted.sort((a, b) => new Date(b.dataset.created || 0) - new Date(a.dataset.created || 0));
      }

      return sorted;
    }

    function updatePagination(totalItems) {
      const totalPages = Math.ceil(totalItems / itemsPerPage);
      prevPageBtn.disabled = currentPage === 1;
      nextPageBtn.disabled = currentPage >= totalPages || totalPages === 0;
      pageNumbersDiv.innerHTML = totalPages ? `Page ${currentPage} of ${totalPages}` : "";
    }

    function render() {
      const filtered = sortCards(getFiltered());
      const start = (currentPage - 1) * itemsPerPage;
      const visible = filtered.slice(start, start + itemsPerPage);

      cards.forEach((card) => {
        card.style.display = "none";
      });

      visible.forEach((card) => {
        grid.appendChild(card);
        card.style.display = "block";
      });

      updatePagination(filtered.length);
    }

    searchInput.addEventListener("input", () => {
      currentPage = 1;
      render();
    });

    sortFilter.addEventListener("change", () => {
      currentPage = 1;
      render();
    });

    prevPageBtn.addEventListener("click", () => {
      if (currentPage > 1) {
        currentPage -= 1;
        render();
      }
    });

    nextPageBtn.addEventListener("click", () => {
      const totalPages = Math.ceil(getFiltered().length / itemsPerPage);
      if (currentPage < totalPages) {
        currentPage += 1;
        render();
      }
    });

    render();
  });
</script>
