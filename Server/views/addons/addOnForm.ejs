<%- include('../layouts/header') %>

<div class="container">
  <h2 class="mb-30"><%= isEdit ? 'Edit Add-On' : 'Create Add-On' %></h2>

  <div class="movie-detail-container">
    <form
      id="addOnForm"
      action="<%= isEdit ? '/addons/edit/' + addOn._id : '/addons/create' %>"
      method="POST"
      enctype="multipart/form-data"
      style="display: contents;"
    >
      <input type="hidden" name="returnTo" value="<%= returnTo || '/addons' %>">

      <div class="movie-detail-poster">
        <label for="picture" style="cursor: pointer; display: block;">
          <img
            id="placeholderImg"
            src="<%= isEdit && addOn && addOn.pictureUrl ? addOn.pictureUrl : '/images/cameraplaceholder.jpg' %>"
            alt="Upload add-on image"
            style="width: 100%; border-radius: 8px; border: 2px dashed #94a3b8; object-fit: cover; min-height: 400px;"
          >
        </label>
        <input type="file" id="picture" name="picture" accept="image/*" style="display: none;">
        <input type="hidden" id="pictureUrl" name="pictureUrl" value="<%= addOn && addOn.pictureUrl ? addOn.pictureUrl : '' %>">
        <p class="form-help-text">Click to upload image</p>
      </div>

      <div class="movie-detail-info">
        <div class="form-group">
          <div class="label-row">
            <label for="name" class="form-label">Add-On Name *</label>
            <% if (typeof error !== 'undefined' && error) { %>
              <span class="error-inline">
                <i class="bi bi-exclamation-triangle" style="font-size: 13px;"></i> <%= error %>
              </span>
            <% } %>
          </div>
          <input type="text" id="name" name="name" class="form-control" value="<%= addOn ? addOn.name : '' %>" required maxlength="80">
        </div>

        <div class="form-group">
          <label for="price" class="form-label">Price (SGD)</label>
          <input type="number" id="price" name="price" class="form-control" value="<%= addOn ? addOn.price : '' %>" min="0" step="0.01">
        </div>

        <div class="form-group">
          <label for="description" class="form-label">Description</label>
          <textarea id="description" name="description" rows="6" class="form-control" style="resize: vertical;"><%= addOn ? addOn.description : '' %></textarea>
        </div>

        <div class="movie-detail-actions">
          <a href="<%= returnTo || '/addons' %>" class="btn btn-secondary">
            ← Back to Add-Ons
          </a>
          <button type="submit" class="btn btn-primary">
            <%= isEdit ? 'Update Add-On' : 'Create Add-On' %>
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
  (function () {
    const pictureInput = document.getElementById('picture');
    const pictureUrlInput = document.getElementById('pictureUrl');
    const placeholderImg = document.getElementById('placeholderImg');
    const form = document.getElementById('addOnForm');
    const nameInput = document.getElementById('name');
    const priceInput = document.getElementById('price');
    const fallbackPoster = '/images/cameraplaceholder.jpg';

    function setPreview(src) {
      if (!placeholderImg) return;
      placeholderImg.src = src || fallbackPoster;
    }

    if (pictureInput) {
      pictureInput.addEventListener('change', () => {
        const file = pictureInput.files && pictureInput.files[0];
        if (!file) return;
        setPreview(URL.createObjectURL(file));
        if (pictureUrlInput) pictureUrlInput.value = '';
      });
    }

    if (form) {
      form.addEventListener('submit', (event) => {
        const name = (nameInput?.value || '').trim();
        const price = Number.parseFloat((priceInput?.value || '').trim() || '0');

        if (!name) {
          event.preventDefault();
          nameInput.setCustomValidity('Add-on name is required.');
          nameInput.reportValidity();
          return;
        }
        nameInput.setCustomValidity('');

        if (!Number.isFinite(price) || price < 0) {
          event.preventDefault();
          priceInput.setCustomValidity('Price must be 0 or more.');
          priceInput.reportValidity();
          return;
        }
        priceInput.setCustomValidity('');
      });
    }
  })();
</script>

<%- include('../layouts/footer') %>
