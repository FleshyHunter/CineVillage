<%- include('../layouts/header') %>

<div class="container">
  <div class="movie-detail-container">
    <div class="movie-detail-poster">
      <img src="<%= addOn.pictureUrl || '/images/placeholder.jpg' %>" alt="<%= addOn.name || 'Add-On' %>">
    </div>

    <div class="movie-detail-info detail-info-actions-bottom">
      <h1 class="movie-title"><%= addOn.name || 'N/A' %></h1>

      <div class="detail-grid">
        <div class="detail-item">
          <span class="detail-label">PRICE</span>
          <span class="detail-value"><%= Number(addOn.price || 0).toLocaleString('en-SG', { style: 'currency', currency: 'SGD' }) %></span>
        </div>

        <div class="detail-item full-width">
          <span class="detail-label">DESCRIPTION</span>
          <span class="detail-value"><%= addOn.description || 'N/A' %></span>
        </div>
      </div>

      <div class="movie-detail-actions">
        <a href="<%= returnTo || '/addons' %>" class="btn btn-secondary">
          ← Back to Add-Ons
        </a>
        <% if (currentRole !== 'Staff') { %>
          <a href="/addons/edit/<%= addOn._id %>?returnTo=<%= encodeURIComponent(returnTo || '/addons') %>" class="btn btn-primary">
            <i class="bi bi-pencil-square"></i> Edit Add-On
          </a>
        <% } %>
      </div>
    </div>
  </div>

  <% if (currentRole !== 'Staff') { %>
    <div class="text-center mt-30">
      <form action="/addons/delete/<%= addOn._id %>" method="POST" class="inline-block"
        onsubmit="return confirm('Are you sure you want to delete this add-on?');">
        <button type="submit" class="btn btn-danger">
          <i class="bi bi-trash3"></i> Delete Add-On
        </button>
      </form>
    </div>
  <% } %>
</div>

<%- include('../layouts/footer') %>
