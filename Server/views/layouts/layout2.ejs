<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CineVillage<% if (typeof title !== 'undefined' && title) { %> | <%= title %><% } %></title>
  <link rel="icon" type="image/png" href="/images/CVLogo2.png">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/main.css?v=20260304-1">
  <link rel="stylesheet" href="/css/components.css">
</head>
<body>
  <div class="app-layout">
    <!-- Sidebar (1 ratio) - Left Side -->
    <div class="sidebar layout2-sidebar">
      <button type="button" class="sidebar-brand sidebar-brand-button" onclick="window.location.href='/dashboard'">
        <img src="/images/CVLogo2.png" alt="CineVillage Logo" class="sidebar-brand-logo">
        <div class="sidebar-brand-text">
          <h2 class="sidebar-title">CineVillage</h2>
          <p class="sidebar-subtitle">Operations Console</p>
        </div>
      </button>

      <div class="sidebar-nav-group sidebar-nav-group-main">
        <div class="sidebar-nav-label sidebar-nav-label-main">Main</div>
        <a href="/dashboard" class="sidebar-link">
          <i class="bi bi-grid-1x2"></i><span>Dashboard</span>
        </a>
        <a href="/profile" class="sidebar-link">
          <i class="bi bi-person-circle"></i><span>Profile</span>
        </a>
      </div>

      <div class="sidebar-nav-group sidebar-nav-group-management">
        <div class="sidebar-nav-label sidebar-nav-label-management">Management</div>
        <div class="sidebar-nav-group-management-links">
          <a href="/movies" class="sidebar-link">
            <i class="bi bi-film"></i><span>Movies</span>
          </a>
          <% if (currentRole !== 'Staff') { %>
            <a href="/movies/create" class="sidebar-link">
              <i class="bi bi-plus-square"></i><span>Add Movie</span>
            </a>
          <% } %>
          <a href="/halls" class="sidebar-link">
            <i class="bi bi-door-open"></i><span>Halls</span>
          </a>
          <% if (currentRole !== 'Staff') { %>
            <a href="/halls/create" class="sidebar-link">
              <i class="bi bi-building-add"></i><span>Add Hall</span>
            </a>
          <% } %>
          <a href="/screenings" class="sidebar-link">
            <i class="bi bi-calendar-event"></i><span>Screening</span>
          </a>
          <a href="/screenings/create" class="sidebar-link">
            <i class="bi bi-calendar-plus"></i><span>Create Screening</span>
          </a>
          <a href="/bookings" class="sidebar-link">
            <i class="bi bi-ticket-perforated"></i><span>Bookings</span>
          </a>
          <a href="/promotions" class="sidebar-link">
            <i class="bi bi-megaphone"></i><span>Promotions</span>
          </a>
          <% if (currentRole !== 'Staff') { %>
            <a href="/promotions/create" class="sidebar-link">
              <span class="sidebar-icon-combo" aria-hidden="true">
                <i class="bi bi-card-image sidebar-icon-combo-main"></i>
                <i class="bi bi-plus-circle-fill sidebar-icon-combo-badge"></i>
              </span>
              <span>Create Promotion</span>
            </a>
          <% } %>
          <a href="/addons" class="sidebar-link">
            <i class="bi bi-cup-straw"></i><span>Add-Ons</span>
          </a>
          <% if (currentRole !== 'Staff') { %>
            <a href="/addons/create" class="sidebar-link">
              <span class="sidebar-icon-combo" aria-hidden="true">
                <i class="bi bi-cup-straw sidebar-icon-combo-main"></i>
                <i class="bi bi-plus-circle-fill sidebar-icon-combo-badge"></i>
              </span>
              <span>Create Add-On</span>
            </a>
          <% } %>
          <% if (currentRole === 'Admin') { %>
            <a href="/personnel" class="sidebar-link">
              <i class="bi bi-people"></i><span>Personnel List</span>
            </a>
            <a href="/personnel/create?role=staff" class="sidebar-link">
              <i class="bi bi-person-plus"></i><span>Create Personnel</span>
            </a>
          <% } %>
          <% if (currentRole !== 'Staff') { %>
            <a href="/history" class="sidebar-link">
              <i class="bi bi-clock-history"></i><span>History</span>
            </a>
          <% } %>
        </div>
      </div>

      <a href="/auth/logout" class="sidebar-logout-btn">
        <i class="bi bi-box-arrow-right"></i> Sign Out
      </a>
    </div>

    <!-- Main Content Area (n ratio) - Right Side -->
    <div class="main-content">
      <!-- Header -->
      <header class="page-header">
        <!-- <h1 class="header-title">
          <img src="/images/CVLogo2.png" alt="CineVillage Logo" class="header-title-logo">
          <%= typeof pageTitle !== 'undefined' ? pageTitle : 'CineVillage Management' %>
        </h1> -->
        <a href="/profile" class="header-account" title="View profile">
          <img
            src="<%= (currentAccount && currentAccount.pictureUrl) ? currentAccount.pictureUrl : '/images/cameraplaceholder.jpg' %>"
            alt="Current account profile"
            class="header-account-avatar"
          >
          <span class="header-account-name">
            <%= (currentAccount && currentAccount.name) ? currentAccount.name : 'Account' %>
          </span>
        </a>
      </header>

      <!-- Page Content (n ratio area) -->
      <div class="content-wrapper">
        <%- body %>
      </div>

      <!-- Footer -->
      <footer class="page-footer">
        <p>&copy; <%= new Date().getFullYear() %> CineVillage. All Rights Reserved.</p>
      </footer>
    </div>
  </div>

  <div class="modal fade" id="accessDeniedModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content" style="background-color: var(--bg-card); border: 1px solid #334155;">
        <div class="modal-header" style="border-bottom: 1px solid #334155;">
          <h5 class="modal-title text-light">
            <i class="bi bi-shield-lock-fill text-warning" style="margin-right: 8px;"></i>
            Access Denied
          </h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body text-light">
          You do not have the authorisation to access this.
        </div>
        <div class="modal-footer" style="border-top: 1px solid #334155;">
          <button type="button" class="btn btn-primary" data-bs-dismiss="modal">OK</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (() => {
      const currentPath = window.location.pathname;
      const navLinks = Array.from(document.querySelectorAll('.sidebar-link'));
      let bestMatch = null;
      let bestLength = -1;

      navLinks.forEach((link) => {
        const linkPath = new URL(link.href).pathname;
        const isExactMatch = currentPath === linkPath;
        const isNestedMatch = currentPath.startsWith(linkPath + '/');
        const isMatch = isExactMatch || isNestedMatch;

        if (isMatch && linkPath.length > bestLength) {
          bestMatch = link;
          bestLength = linkPath.length;
        }
      });

      if (bestMatch) bestMatch.classList.add('active');

      const params = new URLSearchParams(window.location.search);
      if (params.get('accessDenied') === '1') {
        const modalEl = document.getElementById('accessDeniedModal');
        if (modalEl && window.bootstrap && window.bootstrap.Modal) {
          const modal = new window.bootstrap.Modal(modalEl);
          modal.show();
        }
        params.delete('accessDenied');
        const qs = params.toString();
        const cleanUrl = `${window.location.pathname}${qs ? `?${qs}` : ''}${window.location.hash || ''}`;
        window.history.replaceState({}, '', cleanUrl);
      }
    })();
  </script>
</body>
</html>
