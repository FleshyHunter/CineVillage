<%- include('../layouts/header') %>

<div class="container">
  <div class="movie-detail-container">
    <div class="movie-detail-poster">
      <img src="<%= promotion.pictureUrl || '/images/placeholder.jpg' %>" alt="<%= promotion.name || 'Promotion' %>">
    </div>

    <div class="movie-detail-info detail-info-actions-bottom">
      <h1 class="movie-title"><%= promotion.name || 'N/A' %></h1>
      <%
        const hasPromotionDates = Boolean(promotion.promotionStartDate && promotion.promotionEndDate);
        const promotionStartDateDisplay = hasPromotionDates
          ? new Date(promotion.promotionStartDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
          : '';
        const promotionEndDateDisplay = hasPromotionDates
          ? new Date(promotion.promotionEndDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
          : '';
      %>

      <div class="detail-grid">
        <div class="detail-item">
          <span class="detail-label">DURATION</span>
          <span class="detail-value"><%= hasPromotionDates ? `${promotionStartDateDisplay} - ${promotionEndDateDisplay}` : (promotion.duration ? `${promotion.duration} days` : 'N/A') %></span>
        </div>

        <div class="detail-item">
          <span class="detail-label">CODE</span>
          <span class="detail-value"><%= promotion.code || 'N/A' %></span>
        </div>

        <div class="detail-item">
          <span class="detail-label">TYPE</span>
          <span class="detail-value"><%= (promotion.type || 'all').toString().toUpperCase() %></span>
        </div>

        <div class="detail-item">
          <span class="detail-label">BENEFIT</span>
          <span class="detail-value">
            <% if (promotion.benefit && promotion.benefit.type) { %>
              <%= `${String(promotion.benefit.type).toUpperCase()} · ${promotion.benefit.target || 'cart'} · ${promotion.benefit.value ?? 0}` %>
            <% } else { %>
              N/A
            <% } %>
          </span>
        </div>

        <div class="detail-item">
          <span class="detail-label">USAGE LIMIT</span>
          <span class="detail-value"><%= promotion.usageLimit || promotion?.validity?.usageLimit || 'N/A' %></span>
        </div>

        <div class="detail-item full-width">
          <span class="detail-label">CONDITIONS</span>
          <span class="detail-value">
            <% if (Array.isArray(promotion.conditions) && promotion.conditions.length > 0) { %>
              <ul style="margin: 0; padding-left: 18px;">
                <% promotion.conditions.forEach((condition) => { %>
                  <li><%= `${condition.type || 'N/A'}: ${condition.value ?? 'N/A'}` %></li>
                <% }); %>
              </ul>
            <% } else { %>
              No conditions (applies broadly)
            <% } %>
          </span>
        </div>

        <div class="detail-item full-width">
          <span class="detail-label">DESCRIPTION</span>
          <span class="detail-value"><%= promotion.description || 'N/A' %></span>
        </div>
      </div>

      <div class="movie-detail-actions">
        <a href="<%= returnTo || '/promotions' %>" class="btn btn-secondary">
          ← Back to Promotions
        </a>
        <% if (currentRole !== 'Staff') { %>
          <a href="/promotions/edit/<%= promotion._id %>?returnTo=<%= encodeURIComponent(returnTo || '/promotions') %>" class="btn btn-primary">
            <i class="bi bi-pencil-square"></i> Edit Promotion
          </a>
        <% } %>
      </div>
    </div>
  </div>

  <% if (currentRole !== 'Staff') { %>
    <div class="text-center mt-30">
      <form action="/promotions/delete/<%= promotion._id %>" method="POST" class="inline-block"
        onsubmit="return confirm('Are you sure you want to delete this promotion?');">
        <button type="submit" class="btn btn-danger">
          <i class="bi bi-trash3"></i> Delete Promotion
        </button>
      </form>
    </div>
  <% } %>
</div>

<%- include('../layouts/footer') %>
