<%- include('../layouts/header') %>
<link rel="stylesheet" href="/css/hall.css">

<div class="container">
  <h2 class="mb-30"><%= hall.name || 'Hall Details' %></h2>
  
  <div class="hall-form-container">
    
    <!-- Left Side: Hall Information -->
    <div class="hall-form-fields">
      <h3 class="section-title">HALL INFORMATION</h3>
      
      <div class="flex-column-gap-12">
        <div class="form-group">
          <label class="form-label-compact">TYPE</label>
          <div class="form-control form-control-readonly"><%= hall.type || 'N/A' %></div>
        </div>
        
        <div class="form-group">
          <label class="form-label-compact">STATUS</label>
          <%
            const detailHallStatus = hall.configuredStatus || hall.status || 'N/A';
            const detailMaintenanceStart = hall.maintenanceStartDate || '';
            const detailMaintenanceEnd = hall.maintenanceEndDate || '';
            const formatDateShort = (dateStr) => {
              if (!dateStr || !/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) return dateStr;
              const [yyyy, mm, dd] = dateStr.split('-');
              return `${dd}/${mm}/${yyyy.slice(2)}`;
            };
            const detailMaintenanceRange = (detailMaintenanceStart && detailMaintenanceEnd)
              ? ` (${formatDateShort(detailMaintenanceStart)} - ${formatDateShort(detailMaintenanceEnd)})`
              : '';
            const detailStatusText = detailHallStatus === 'Available'
              ? 'Available'
              : `Under Maintenance${detailMaintenanceRange}`;
          %>
          <div class="form-control form-control-readonly">
            <%= detailStatusText %>
          </div>
        </div>
        
        <div class="form-group">
          <label class="form-label-compact">CAPACITY</label>
          <div class="form-control form-control-readonly"><%= hall.capacity || 'N/A' %> seats</div>
        </div>
        
        <div class="form-row">
          <div class="form-group">
            <label class="form-label-compact">ROWS</label>
            <div class="form-control form-control-readonly"><%= hall.rows || 'N/A' %></div>
          </div>
          
          <div class="form-group">
            <label class="form-label-compact">COLUMNS</label>
            <div class="form-control form-control-readonly"><%= hall.columns || 'N/A' %></div>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="movie-detail-actions mt-30">
        <a href="/halls" class="btn btn-secondary">
          ← Back to Halls
        </a>
        <% if (currentRole !== 'Staff') { %>
          <a href="/halls/edit/<%= hall._id %>" class="btn btn-primary">
            <i class="bi bi-pencil-square"></i> Edit Hall
          </a>
        <% } %>
      </div>

      <!-- Delete Form -->
      <% if (currentRole !== 'Staff') { %>
        <div class="text-center mt-20">
          <% if (typeof deleteError !== 'undefined' && deleteError) { %>
            <div class="alert alert-danger" role="alert" style="margin-bottom: 12px;">
              <i class="bi bi-exclamation-triangle-fill"></i> <%= deleteError %>
            </div>
          <% } %>
          <form action="/halls/delete/<%= hall._id %>" method="POST" class="inline-block"
            onsubmit="return confirm('Are you sure you want to delete this hall?');">
            <button type="submit" class="btn btn-danger" <%= totalLinkedScreeningCount > 0 ? 'disabled' : '' %>>
              <i class="bi bi-trash3"></i> Delete Hall
            </button>
          </form>
          <% if (totalLinkedScreeningCount > 0) { %>
            <p style="margin-top: 8px; color: #f59e0b; font-size: 13px;">
              This hall has <%= activeLinkedScreeningCount %> active screening(s) (<%= totalLinkedScreeningCount %> total) and cannot be deleted.
            </p>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- Right Side: Seat Layout Visualization -->
    <div>
      <div class="hall-seat-layout-detail">
        <h3 class="section-title text-center">SEAT LAYOUT</h3>
        
        <!-- Screen -->
        <div class="screen-display">
          <div class="screen-label">SCREEN</div>
        </div>

        <!-- Seat Grid Container -->
        <div id="seatGridDetail" class="seat-grid-container">
          <!-- Seats will be generated here by JavaScript -->
        </div>

        <!-- Legend -->
        <div class="seat-legend">
          <div class="legend-item">
            <div class="legend-seat normal"></div>
            <span>Normal</span>
          </div>
          <div class="legend-item">
            <div class="legend-seat removed"></div>
            <span>Removed</span>
          </div>
          <div class="legend-item">
            <div class="legend-seat wheelchair"></div>
            <span>Wheelchair</span>
          </div>
          <div class="legend-item">
            <div class="legend-lane"></div>
            <span>Lane</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script src="/js/hallDetails.js"></script>
<script>
  // Initialize hall data and generate seat display
  setHallData(
    <%= hall.rows || 0 %>,
    <%= hall.columns || 0 %>,
    <%= hall.wingColumns || 0 %>,
    <%- hall.seatConfig ? JSON.stringify(hall.seatConfig) : '{}' %>
  );
</script>

<%- include('../layouts/footer') %>
