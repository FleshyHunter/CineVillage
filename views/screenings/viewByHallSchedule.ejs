
<%- include('../layouts/header') %>

<div class="container" data-hall-id="<%= hall._id %>">
    <h2 class="mb-30"><%= hall.name %> - Schedule</h2>

    <div class="movie-detail-container">
        <!-- Left Side: Hall Image -->
        <div class="movie-detail-poster">
            <img src="<%= hall.pictureUrl || '/images/placeholder.jpg' %>"
                alt="<%= hall.name %>"
                class="detail-cover-img">
            <div class="detail-meta-block detail-meta-block-center">
                <h4 class="detail-meta-title"><%= hall.name %></h4>
                <p class="detail-meta-subtitle"><%= hall.type %> | <%= hall.capacity %> seats</p>
            </div>
        </div>

        <!-- Right Side: Calendar and Timeline -->
        <div class="movie-detail-info">
            
            <!-- Date Selection -->
            <div class="form-group">
                <label for="dateInput" class="form-label">SELECT DATE</label>
                <input type="date" id="dateInput" class="form-control" 
                       value="<%= selectedDate %>"
                       min="<%= new Date().toISOString().split('T')[0] %>"
                       max="<%= new Date(new Date().setMonth(new Date().getMonth() + 3)).toISOString().split('T')[0] %>">
            </div>

            <!-- Screenings List for Selected Date -->
            <div id="selectedDateScreeningsContainer" class="selected-date-screenings">
                <label class="form-label section-title-sm">SCREENINGS FOR SELECTED DATE</label>
                <div class="schedule-panel">
                    <div class="schedule-card-header">
                        <i class="bi bi-calendar3 schedule-card-icon"></i>
                        <h4 id="selectedDateHeading" class="schedule-card-title"></h4>
                    </div>
                    <div id="selectedDateScreeningsList" class="selected-date-list"></div>
                    <div id="selectedDatePagination" class="pagination-container selected-date-pagination">
                        <button id="selectedDatePrevPage" class="pagination-btn" disabled>
                            <i class="bi bi-chevron-left"></i> Previous
                        </button>
                        <div id="selectedDatePageNumbers" class="page-numbers"></div>
                        <button id="selectedDateNextPage" class="pagination-btn">
                            Next <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>

            
            <!-- Hall Schedule Timeline -->
            <div id="timelineContainer" class="timeline-container">
                <label class="form-label section-title-sm">HALL SCHEDULE</label>
                <div class="schedule-panel schedule-panel-compact">
                    
                    <!-- Legend -->
                    <div class="timeline-legend">
                        <div class="timeline-legend-item">
                            <div class="timeline-legend-dot timeline-legend-dot-occupied"></div>
                            <span class="timeline-legend-text">Occupied</span>
                        </div>
                        <div class="timeline-legend-item">
                            <div class="timeline-legend-dot timeline-legend-dot-available"></div>
                            <span class="timeline-legend-text">Available</span>
                        </div>
                    </div>

                    <!-- Timeline: First 12 hours (00:00 - 11:45) -->
                    <div class="timeline-row-block">
                        <div id="dateLabel1" class="timeline-date-label"></div>
                        <div class="timeline-range-label">00:00 - 11:45</div>
                        <div id="timeline-row1" class="timeline-grid">
                            <!-- Slots generated by JavaScript -->
                        </div>
                        <div class="timeline-ticks">
                            <span class="timeline-tick">00:00</span>
                            <span class="timeline-tick">03:00</span>
                            <span class="timeline-tick">06:00</span>
                            <span class="timeline-tick">09:00</span>
                            <span class="timeline-tick">11:45</span>
                        </div>
                    </div>

                    <!-- Timeline: Second 12 hours (12:00 - 23:45) -->
                    <div class="timeline-row-block">
                        <div class="timeline-range-label">12:00 - 23:45</div>
                        <div id="timeline-row2" class="timeline-grid">
                            <!-- Slots generated by JavaScript -->
                        </div>
                        <div class="timeline-ticks">
                            <span class="timeline-tick">12:00</span>
                            <span class="timeline-tick">15:00</span>
                            <span class="timeline-tick">18:00</span>
                            <span class="timeline-tick">21:00</span>
                            <span class="timeline-tick">23:45</span>
                        </div>
                    </div>

                    <!-- Timeline: Next day morning (00:00 - 11:45) -->
                    <div>
                        <div id="dateLabel2" class="timeline-date-label"></div>
                        <div class="timeline-range-label">00:00 - 11:45</div>
                        <div id="timeline-row3" class="timeline-grid">
                            <!-- Slots generated by JavaScript -->
                        </div>
                        <div class="timeline-ticks">
                            <span class="timeline-tick">00:00</span>
                            <span class="timeline-tick">03:00</span>
                            <span class="timeline-tick">06:00</span>
                            <span class="timeline-tick">09:00</span>
                            <span class="timeline-tick">11:45</span>
                        </div>
                    </div>

                    <div id="timelineMessage" class="timeline-message">
                        Loading schedule...
                    </div>
                </div>
            </div>

            <!-- Back Button -->
            <div class="movie-detail-actions">
                <a href="/screenings?view=hall" class="btn btn-secondary">
                    ← Back to Hall List
                </a>
            </div>

        </div>
    </div>
</div>

<script>
    const dateInput = document.getElementById('dateInput');
    const timelineRow1 = document.getElementById('timeline-row1');
    const timelineRow2 = document.getElementById('timeline-row2');
    const timelineRow3 = document.getElementById('timeline-row3');
    const timelineMessage = document.getElementById('timelineMessage');
    const dateLabel1 = document.getElementById('dateLabel1');
    const dateLabel2 = document.getElementById('dateLabel2');
    const selectedDateHeading = document.getElementById('selectedDateHeading');
    const selectedDateScreeningsList = document.getElementById('selectedDateScreeningsList');
    const selectedDatePrevPage = document.getElementById('selectedDatePrevPage');
    const selectedDateNextPage = document.getElementById('selectedDateNextPage');
    const selectedDatePageNumbers = document.getElementById('selectedDatePageNumbers');
    const hallId = '<%= hall._id %>';
    
    let currentSchedule = [];
    let selectedDateCurrentPage = 1;
    const selectedDateItemsPerPage = 5;

    // Generate timeline slots
    function generateTimelineSlots() {
        timelineRow1.innerHTML = '';
        timelineRow2.innerHTML = '';
        timelineRow3.innerHTML = '';
        
        for (let i = 0; i < 48; i++) {
            // Row 1: Slots 0-47
            const slot1 = document.createElement('div');
            slot1.className = 'timeline-slot available';
            slot1.dataset.slot = i;
            slot1.title = formatSlotTime(i);
            timelineRow1.appendChild(slot1);
            
            // Row 2: Slots 48-95
            const slot2 = document.createElement('div');
            slot2.className = 'timeline-slot available';
            slot2.dataset.slot = i + 48;
            slot2.title = formatSlotTime(i + 48);
            timelineRow2.appendChild(slot2);
            
            // Row 3: Slots 96-143
            const slot3 = document.createElement('div');
            slot3.className = 'timeline-slot available';
            slot3.dataset.slot = i + 96;
            slot3.title = formatSlotTime(i);
            timelineRow3.appendChild(slot3);
        }
    }

    // Format slot number to time string
    function formatSlotTime(slot) {
        const adjustedSlot = slot % 96;
        const totalMinutes = adjustedSlot * 15;
        const hours = Math.floor(totalMinutes / 60);
        const minutes = totalMinutes % 60;
        return `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}`;
    }
    
    // Update date labels
    function updateDateLabels() {
        const selectedDate = new Date(dateInput.value + 'T00:00:00');
        const nextDate = new Date(selectedDate);
        nextDate.setDate(nextDate.getDate() + 1);
        
        const formatDate = (date) => {
            const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
            const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
            return `${days[date.getDay()]}, ${date.getDate()} ${months[date.getMonth()]} ${date.getFullYear()}`;
        };
        
        dateLabel1.textContent = formatDate(selectedDate);
        dateLabel2.textContent = formatDate(nextDate);
    }

    function renderSelectedDateScreenings() {
        if (!selectedDateHeading || !selectedDateScreeningsList || !dateInput.value) {
            return;
        }

        const selectedDate = new Date(dateInput.value + 'T00:00:00');
        const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
        const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        selectedDateHeading.textContent = `${days[selectedDate.getDay()]}, ${selectedDate.getDate()} ${months[selectedDate.getMonth()]} ${selectedDate.getFullYear()}`;

        selectedDateScreeningsList.innerHTML = '';
        const totalPages = Math.max(1, Math.ceil(currentSchedule.length / selectedDateItemsPerPage));
        if (selectedDateCurrentPage > totalPages) {
            selectedDateCurrentPage = totalPages;
        }

        if (!currentSchedule.length) {
            selectedDateScreeningsList.innerHTML = '<p class="selected-screenings-empty">No screenings scheduled for this date</p>';
        } else {
            const startIndex = (selectedDateCurrentPage - 1) * selectedDateItemsPerPage;
            const endIndex = startIndex + selectedDateItemsPerPage;
            const paginatedSchedule = currentSchedule.slice(startIndex, endIndex);

            paginatedSchedule.forEach(block => {
                const item = document.createElement('a');
                item.className = 'selected-screening-item';
                item.href = `/screenings/view/${block.screeningId}?returnTo=${encodeURIComponent(`/screenings/hall/${hallId}?date=${dateInput.value}`)}`;
                item.title = `View ${block.movieName}`;

                const movieName = document.createElement('div');
                movieName.className = 'selected-screening-name';
                movieName.textContent = block.movieName || 'Untitled Movie';

                const timing = document.createElement('div');
                timing.className = 'selected-screening-time';
                timing.textContent = `${block.displayStart} - ${block.displayEnd}`;

                item.appendChild(movieName);
                item.appendChild(timing);
                selectedDateScreeningsList.appendChild(item);
            });
        }

        if (selectedDatePrevPage && selectedDateNextPage && selectedDatePageNumbers) {
            selectedDatePrevPage.disabled = selectedDateCurrentPage === 1;
            selectedDateNextPage.disabled = selectedDateCurrentPage === totalPages;
            selectedDatePageNumbers.innerHTML = '';
            const pageInfo = document.createElement('span');
            pageInfo.className = 'page-number active';
            pageInfo.textContent = `Page ${selectedDateCurrentPage} of ${totalPages}`;
            selectedDatePageNumbers.appendChild(pageInfo);
        }
    }

    // Load hall schedule
    async function loadHallSchedule() {
        const date = dateInput.value;
        
        if (!date) {
            return;
        }
        
        try {
            timelineMessage.textContent = 'Loading schedule...';
            
            const response = await fetch(`/screenings/api/schedule/${hallId}/${date}`);
            if (!response.ok) {
                throw new Error('Failed to fetch schedule');
            }
            
            currentSchedule = await response.json();
            renderSelectedDateScreenings();
            
            // Generate fresh slots
            generateTimelineSlots();
            
            // Mark occupied slots
            currentSchedule.forEach(block => {
                for (let slot = block.startSlot; slot < block.endSlot; slot++) {
                    const slotElement = document.querySelector(`.timeline-slot[data-slot="${slot}"]`);
                    if (slotElement) {
                        slotElement.classList.remove('available');
                        slotElement.classList.add('occupied');
                        slotElement.title = `${block.movieName} (${block.displayStart} - ${block.displayEnd})`;
                    }
                }
            });
            
            if (currentSchedule.length > 0) {
                timelineMessage.textContent = `${currentSchedule.length} screening(s) scheduled`;
            } else {
                timelineMessage.textContent = 'No screenings scheduled for this date';
            }
        } catch (error) {
            console.error('Error loading schedule:', error);
            timelineMessage.textContent = 'Error loading schedule';
            currentSchedule = [];
            renderSelectedDateScreenings();
        }
    }

    // Date selection
    dateInput.addEventListener('change', function() {
        selectedDateCurrentPage = 1;
        updateDateLabels();
        loadHallSchedule();
    });

    if (selectedDatePrevPage) {
        selectedDatePrevPage.addEventListener('click', function() {
            if (selectedDateCurrentPage > 1) {
                selectedDateCurrentPage--;
                renderSelectedDateScreenings();
            }
        });
    }

    if (selectedDateNextPage) {
        selectedDateNextPage.addEventListener('click', function() {
            const totalPages = Math.max(1, Math.ceil(currentSchedule.length / selectedDateItemsPerPage));
            if (selectedDateCurrentPage < totalPages) {
                selectedDateCurrentPage++;
                renderSelectedDateScreenings();
            }
        });
    }

    // Initialize on page load
    updateDateLabels();
    loadHallSchedule();
</script>

<%- include('../layouts/footer') %>
