<html lang="en">
  <%- include('../layouts/header') %>
  <body>
    <div class="auth-login-page">
      <div class="auth-login-shell">
        <section class="auth-login-hero">
          <div class="sidebar-brand">
            <img src="/images/CVLogo2.png" alt="CineVillage Logo" class="sidebar-brand-logo">
            <div class="sidebar-brand-text">
              <h2 class="sidebar-title">CineVillage</h2>
              <p class="sidebar-subtitle">Operations Console</p>
            </div>
          </div>

          <p class="auth-login-kicker">Management Access</p>
          <h1 class="auth-login-heading">Run Daily Cinema Operations With Confidence.</h1>
          <p class="auth-login-subtext">
            Manage movies, halls, screenings, and personnel from one centralized dashboard.
          </p>
        </section>

        <section class="auth-login-panel">
          <h2 class="auth-login-title">Sign In</h2>
          <p class="auth-login-caption">Use your CineVillage account credentials.</p>

          <% if (typeof info !== 'undefined' && info) { %>
            <div class="auth-login-info"><%= info %></div>
          <% } %>

          <% if (typeof error !== 'undefined' && error) { %>
            <div class="auth-login-error"><%= error %></div>
          <% } %>

          <form action="/auth/login" method="POST">
            <div class="auth-login-field">
              <label for="email" class="auth-login-label">Email</label>
              <input type="text" id="email" name="email" class="auth-login-input" required>
            </div>

            <div class="auth-login-field-lg">
              <label for="password" class="auth-login-label">Password</label>
              <input type="password" id="password" name="password" class="auth-login-input" required>
            </div>

            <button type="submit" class="btn btn-primary auth-login-submit">Login</button>
          </form>

          <p class="auth-login-help">
            Forgot your password? <a href="/auth/reset">Reset here</a>
          </p>
        </section>
      </div>
    </div>
  </body>
</html>
