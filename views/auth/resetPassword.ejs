<html lang="en">
  <%- include('../layouts/header') %>
  <body>
    <div class="auth-login-page">
      <div class="auth-login-shell">
        <section class="auth-login-hero">
          <div class="sidebar-brand">
            <img src="/images/CVLogo2.png" alt="CineVillage Logo" class="sidebar-brand-logo">
            <div class="sidebar-brand-text">
              <h2 class="sidebar-title">CineVillage</h2>
              <p class="sidebar-subtitle">Operations Console</p>
            </div>
          </div>

          <p class="auth-login-kicker">Recovery Access</p>
          <h1 class="auth-login-heading">Set A New Password.</h1>
          <p class="auth-login-subtext">
            Choose a new password to regain access to your account.
          </p>
        </section>

        <section class="auth-login-panel">
          <h2 class="auth-login-title">Create New Password</h2>
          <p class="auth-login-caption">Your reset link is valid for a limited time.</p>

          <% if (typeof error !== 'undefined' && error) { %>
            <div class="auth-login-error"><%= error %></div>
          <% } %>

          <% if (typeof invalidToken !== 'undefined' && invalidToken) { %>
            <div class="auth-login-error">This reset link is invalid or has expired.</div>
            <p class="auth-login-help">
              Request a new link? <a href="/auth/reset">Reset here</a>
            </p>
          <% } else { %>
            <form action="/auth/reset/<%= token %>" method="POST">
              <div class="auth-login-field">
                <label for="newPassword" class="auth-login-label">New Password</label>
                <input type="password" id="newPassword" name="newPassword" class="auth-login-input" required>
              </div>

              <div class="auth-login-field-lg">
                <label for="confirmPassword" class="auth-login-label">Confirm Password</label>
                <input type="password" id="confirmPassword" name="confirmPassword" class="auth-login-input" required>
              </div>

              <button type="submit" class="btn btn-primary auth-login-submit">Update Password</button>
            </form>
          <% } %>

          <p class="auth-login-help">
            Back to login? <a href="/auth/login">Sign in here</a>
          </p>
        </section>
      </div>
    </div>
  </body>
</html>
