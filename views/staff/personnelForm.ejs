<div class="container" style="width: 100%; max-width: none;">
  <h2 class="mb-30">Create Personnel</h2>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="error-banner"><%= error %></div>
  <% } %>

  <div class="card" style="width: 100%;">
    <h3 class="section-title"><%= isEdit ? 'Update Personnel Information' : 'New Personnel Information' %></h3>

    <form action="<%= isEdit ? `/personnel/edit/${role}/${personnel._id}` : `/personnel/create?role=${role}` %>" method="POST">

      <div class="form-row">
        <div class="form-group">
          <label for="name" class="form-label-compact">NAME *</label>
          <input id="name" name="name" type="text" class="form-control" value="<%= personnel ? (personnel.name || '') : '' %>" required>
        </div>
        <div class="form-group">
          <label for="username" class="form-label-compact">USERNAME *</label>
          <input id="username" name="username" type="text" class="form-control" value="<%= personnel ? (personnel.username || '') : '' %>" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="email" class="form-label-compact">EMAIL *</label>
          <input id="email" name="email" type="email" class="form-control" value="<%= personnel ? (personnel.email || '') : '' %>" required>
        </div>
        <div class="form-group">
          <label for="contact" class="form-label-compact">CONTACT *</label>
          <input id="contact" name="contact" type="text" class="form-control" value="<%= personnel ? (personnel.contact || '') : '' %>" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label-compact">ROLE</label>
          <select id = "role" name="role" class="form-control" required>
            <option value="manager" <%= role == 'manager' ? 'selected' : '' %>>Manager</option>
            <option value="staff" <%= role == 'staff' ? 'selected' : '' %>>Staff</option>
          </select>
        </div>
        <div class="form-group">
          <label for="status" class="form-label-compact">STATUS *</label>
          <select id="status" name="status" class="form-control" required>
            <option value="Active" <%= personnel && personnel.status === 'Active' ? 'selected' : (!personnel ? 'selected' : '') %>>Active</option>
            <option value="Inactive" <%= personnel && personnel.status === 'Inactive' ? 'selected' : '' %>>Inactive</option>
          </select>
        </div>
      </div>

      <div class="movie-detail-actions mt-30">
        <a href="/personnel?view=<%= role %>" class="btn btn-secondary">← Back to Personnel</a>
        <button type="submit" class="btn btn-primary"><%= isEdit ? 'Update Personnel' : 'Create Personnel' %></button>
      </div>
    </form>
  </div>
</div>
